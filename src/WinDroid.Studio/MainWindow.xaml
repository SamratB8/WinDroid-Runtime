<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinDroid.Studio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinDroid Runtime">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="12">
        <TextBlock
            Text="WinDroid Runtime"
            HorizontalAlignment="Center"
            Style="{StaticResource TitleLargeTextBlockStyle}" />
        <TextBlock
            Text="Initial development environment"
            HorizontalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource BodyTextBlockStyle}" />

        <Button
            x:Name="SelectApkButton"
            Content="Select APK"
            Click="SelectApkButton_Click"
            HorizontalAlignment="Center"
            Style="{ThemeResource AccentButtonStyle}" />

        <TextBlock
            x:Name="SelectedApkPathTextBlock"
            Text="No APK selected"
            HorizontalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource BodyTextBlockStyle}" />
    </StackPanel>

</Window>
